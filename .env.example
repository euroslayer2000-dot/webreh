# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าตามเครื่องของคุณ
# (.env ต้องไม่ commit ขึ้น git — ดู .gitignore)

APP_ENV=local          # local | production
APP_DEBUG=true         # true บนเครื่อง dev, false บน production
APP_URL=http://localhost/school-website/public

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=school_pr
DB_USER=root
DB_PASS=
